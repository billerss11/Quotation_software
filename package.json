{
  "name": "quotation-software",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "description": "Windows-first desktop quotation application.",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.node.json && node scripts/copy-electron-assets.mjs",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest",
    "package:win": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.33",
    "vue-i18n": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "build": {
    "appId": "com.cx.quotationsoftware",
    "productName": "Quotation Software",
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
